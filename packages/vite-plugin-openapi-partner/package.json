{
  "name": "vite-plugin-openapi-partner",
  "version": "0.1.0",
  "description": "Vite plugin for fetching OpenAPI generated types from openapi-partner platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "keywords": [
    "openapi",
    "swagger",
    "vite",
    "plugin",
    "typescript",
    "api-client"
  ],
  "license": "MIT"
}
