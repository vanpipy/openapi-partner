# ===========================================
# Environment Configuration Template
# ===========================================
# Copy this file to .env.development or .env.production
# and fill in your values

# Node environment (development, production, test)
NODE_ENV=development

# Database path (relative to project root)
# For production, consider using an absolute path with a volume mount
DATABASE_PATH=./data/config.db

# Alternative: Database URL for libsql client
# DATABASE_URL=file:./data/config.db

# Session secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-super-secret-key-min-32-chars-here

# Session max age in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# ===========================================
# Client-exposed variables (NEXT_PUBLIC_)
# These are bundled into the frontend code
# ===========================================

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application name
NEXT_PUBLIC_APP_NAME=Config Platform

# ===========================================
# Optional: Webhook configuration
# ===========================================

# Webhook URL for config change notifications
# WEBHOOK_URL=https://your-webhook-endpoint.com/notify

# Webhook secret for signature verification
# WEBHOOK_SECRET=your-webhook-secret
